# ============================================================
# MUUA — Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# El archivo .env NO se sube a git.
# ============================================================

# --- Base de datos PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=muua_db

# --- Cloudinary (subida de imágenes) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- JWT (seguridad del API) ---
JWT_SECRET=cadena_secreta_larga_y_aleatoria_min_32_caracteres
JWT_EXPIRATION_MS=86400000
