# Proxy (setupProxy.js): backend en 127.0.0.1:8080 por defecto.
# PROXY_TARGET=http://127.0.0.1:9090

# Demostración si el API no responde:
# - En npm start está ACTIVADA por defecto (obras de ejemplo sin backend).
# - Pon false para forzar solo datos reales del API (verás colección vacía si no hay backend):
# REACT_APP_USE_DEMO_FALLBACK=false

# No fuerces REACT_APP_API_URL=http://localhost:8080/api (rompe el proxy del puerto 3000).
